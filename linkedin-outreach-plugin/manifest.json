{
  "manifest_version": 3,
  "name": "LinkedIn Outreach Bot",
  "version": "1.1.0",
  "description": "Automate LinkedIn connections with templates or LLM generation and sync with Google Sheets.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://api.groq.com/*",
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*"
      ],
      "css": [
        "style.css"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Outreach Bot"
  }
}
